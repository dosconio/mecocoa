# ASCII Makefile TAB4 LF
# Attribute: Ubuntu(64) Shell(Bash)
# ModuTitle: Build subapps for Mecocoa x86

BIN_DIR = $(uobjpath)/sapp-$(arch)
LIBX86 = $(uobjpath)/$(ACCM_LIBS)/libx86.a
MCCA_X86_TOOLCHAIN ?= i686-mcca-elf-
MCCA_X86_TRIPLE ?= i686-mcca
MCCA_X86_SYSROOT ?= accmlib/sysroot
MCCA_X86_CC ?= $(MCCA_X86_TOOLCHAIN)gcc
MCCA_X86_CXX ?= $(MCCA_X86_TOOLCHAIN)g++
MCCA_X86_CRT0 = $(MCCA_X86_SYSROOT)/usr/lib/$(MCCA_X86_TRIPLE)/crt0.o
MCCA_X86_LIBC = $(MCCA_X86_SYSROOT)/usr/lib/$(MCCA_X86_TRIPLE)/libc.a
MCCA_X86_COMFLAGS = $(flag) -I$(uincpath) -I$(uincpath)/c/ISO_IEC_STD -I$(uincpath)/c/API-POSIX -I$(MCCA_X86_SYSROOT)/usr/include

MCCA_X86_CFLAGS = $(MCCA_X86_COMFLAGS) --sysroot=$(MCCA_X86_SYSROOT) -m32 -ffreestanding -fno-builtin -fno-stack-protector -fno-pic -fno-pie -static -nostdlib
MCCA_X86_CXXFLAGS = $(MCCA_X86_CFLAGS) -fno-exceptions -fno-rtti -fno-use-cxa-atexit -std=c++2a
MCCA_X86_LDLIBS = $(MCCA_X86_CRT0) $(MCCA_X86_LIBC) -lgcc -Wl,-m,elf_i386 -Wl,-z,noexecstack -no-pie
STDCPP_APP_CXXFLAGS = -m32 -static -nodefaultlibs -nostartfiles -fno-omit-frame-pointer -fno-stack-protector -fno-pic -fno-builtin -fno-strict-aliasing -ffunction-sections -fdata-sections $(CXW) -std=c++2a
STDCPP_APP_LIBS = -L$(uobjpath)/$(ACCM_LIBS) -lx86 -lstdc++ -lsupc++ -lgcc -lm

.PHONY: all clean

all: $(BIN_DIR) \
	$(BIN_DIR)/init \
	$(BIN_DIR)/cot \
	$(BIN_DIR)/ls \
	\
	$(BIN_DIR)/fault \
	\
	$(BIN_DIR)/cat \
	$(BIN_DIR)/sleep \
	$(BIN_DIR)/pwd \
	$(BIN_DIR)/test \
	$(BIN_DIR)/paint \
	$(BIN_DIR)/cube \
	$(BIN_DIR)/gblock \
	$(BIN_DIR)/_rust \
	$(BIN_DIR)/cp \
	$(BIN_DIR)/rm \
	$(BIN_DIR)/mv \
	$(BIN_DIR)/mkdir \
	$(BIN_DIR)/echo \
	$(BIN_DIR)/clear \
	$(BIN_DIR)/args \
	$(BIN_DIR)/sort \
	$(BIN_DIR)/more \
	$(BIN_DIR)/grep \


$(BIN_DIR):
	mkdir -p $@

$(BIN_DIR)/cot: $(uherpath)/COTLAB/src/cotlab.cpp $(LIBX86) $(MCCA_X86_CRT0)
	@echo "MK appshell"
	$(MCCA_X86_CXX) $(MCCA_X86_CXXFLAGS) -o $@ $< $(MCCA_X86_LDLIBS)

$(BIN_DIR)/sleep: $(uherpath)/unisym/demo/utilities/sleep.cpp $(MCCA_X86_CRT0) $(MCCA_X86_LIBC)
	@echo "MK sleep"
	$(MCCA_X86_CXX) $(MCCA_X86_CXXFLAGS) -o $@ $< $(MCCA_X86_LDLIBS)

$(BIN_DIR)/ls: $(uherpath)/unisym/demo/utilities/ls.cpp $(MCCA_X86_CRT0) $(MCCA_X86_LIBC)
